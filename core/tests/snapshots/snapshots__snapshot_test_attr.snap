#[::core::prelude::v1::test]
fn it_works() -> ::std::process::ExitCode {
    fn body_fn() {
        assert_eq!(2 + 2, 4);
    }
    ::test_fork::test_fork_core::fork(
            ::test_fork::test_fork_core::fork_id!(),
            ::test_fork::test_fork_core::fork_test_name!(it_works),
            body_fn as fn() -> _,
        )
        .expect("forking test failed")
}
